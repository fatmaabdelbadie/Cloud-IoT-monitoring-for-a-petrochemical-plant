# Copy this to .env and fill in your Azure credentials.
# NEVER commit .env to Git.

IOTHUB_DEVICE_CONNECTION_STRING=HostName=<your-hub>.azure-devices.net;DeviceId=<device-id>;SharedAccessKey=<key>
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
EVENT_HUB_NAME=<your-eventhub-name>
CONSUMER_GROUP=$Default
